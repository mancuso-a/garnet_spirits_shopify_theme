{%- if section.settings.text != blank -%}
  <div id="announcement-bar" class="announcement-bar" role="region" aria-label="Annuncio">
    <p class="announcement-bar__text">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__link">{{ section.settings.text }}</a>
      {%- else -%}
        {{ section.settings.text }}
      {%- endif -%}
    </p>
    <button
      id="ann-close"
      class="announcement-bar__close"
      aria-label="Chiudi annuncio">
      ✕
    </button>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Testo annuncio",
      "default": "🍹 Spedizione gratuita per ordini superiori a €60 · Consegna in 2–4 giorni"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (opzionale)"
    }
  ]
}
{% endschema %}
