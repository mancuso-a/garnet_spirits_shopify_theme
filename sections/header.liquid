<header class="site-header" role="banner">

  <!-- Logo -->
  <a href="/" class="site-header__logo" aria-label="{{ shop.name }} - Home">
    {%- if section.settings.logo != blank -%}
      {{ section.settings.logo | image_url: width: 160 | image_tag: loading: 'eager', class: 'site-header__logo-img', alt: shop.name }}
    {%- else -%}
      {{ shop.name | upcase }}<span>®</span>
    {%- endif -%}
  </a>

  <!-- Desktop nav -->
  <nav class="site-nav" aria-label="Navigazione principale">
    {%- for link in linklists['main-menu'].links -%}
      {%- if link.links != blank -%}
        <div class="site-nav__item">
          <a class="site-nav__link{% if link.active %} active{% endif %}" href="{{ link.url }}">
            {{ link.title }}
          </a>
          <div class="nav-dropdown">
            {%- for child in link.links -%}
              <a href="{{ child.url }}">{{ child.title }}</a>
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <a class="site-nav__link{% if link.active %} active{% endif %}"
           href="{{ link.url }}"
           {% if link.active %}aria-current="page"{% endif %}>
          {{ link.title }}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </nav>

  <!-- Actions -->
  <div class="site-header__actions">

    <!-- Search trigger -->
    <button class="cart-trigger" onclick="PredictiveSearch.open()" aria-label="Cerca">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
    </button>

    <!-- Wishlist link -->
    <a href="/pages/wishlist" class="cart-trigger" aria-label="Wishlist">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </a>

    <!-- Cart -->
    <button class="cart-trigger" onclick="CartDrawer.toggle()" aria-label="Apri carrello" aria-controls="cart-drawer">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <span class="visually-hidden">Carrello</span>
      <span class="cart-trigger__count" id="cart-count" aria-live="polite">0</span>
    </button>

    <!-- Hamburger -->
    <button class="hamburger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span><span></span><span></span>
    </button>
  </div>

</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (opzionale, sovrascrive il nome)"
    }
  ]
}
{% endschema %}
