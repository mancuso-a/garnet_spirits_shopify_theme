<div id="newsletter-popup" class="newsletter-popup" role="dialog" aria-modal="true" aria-labelledby="newsletter-popup-title">
  <button class="newsletter-popup__close" onclick="NewsletterPopup.close()" aria-label="Chiudi">✕</button>

  <!-- Decorative header image (optional; CSS has a fallback gradient) -->
  <div class="newsletter-popup__img" aria-hidden="true"></div>

  <div class="newsletter-popup__body">
    <p class="newsletter-popup__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="newsletter-popup__title" id="newsletter-popup-title">{{ section.settings.title }}</h2>
    <p class="newsletter-popup__subtitle">{{ section.settings.subtitle }}</p>

    {%- form 'customer', id: 'newsletter-popup-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter,popup">
      <div class="newsletter-popup__form">
        <input
          type="email"
          name="contact[email]"
          id="newsletter-popup-email"
          class="newsletter-popup__input"
          placeholder="{{ section.settings.placeholder }}"
          required
          autocomplete="email">
        <button type="submit" class="btn btn--primary" style="padding:.7rem 1.1rem;font-size:.75rem;white-space:nowrap;">
          {{ section.settings.button_label }}
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="color:#2ecc71;font-size:.78rem;margin-top:.75rem;">✓ Benvenuto nel mondo Garnet!</p>
      {%- endif -%}
    {%- endform -%}

    <button class="newsletter-popup__no-thanks" onclick="NewsletterPopup.close()">
      No grazie, continua senza iscriverti
    </button>
  </div>
</div>

{% schema %}
{
  "name": "Newsletter Popup",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Sopratitolo",
      "default": "Unisciti alla community"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titolo",
      "default": "Il mondo Garnet inizia qui"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sottotitolo",
      "default": "Iscriviti alla newsletter: ricette esclusive, anteprime e storie dalla distilleria."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder campo email",
      "default": "La tua email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo bottone",
      "default": "Iscriviti"
    }
  ]
}
{% endschema %}
