{%- assign is_bitter = false -%}
{%- if product.type contains 'Bitter' or product.title contains 'Bitter' -%}
  {%- assign is_bitter = true -%}
{%- endif -%}

{%- assign hero_class = 'product-hero--gin' -%}
{%- assign tag_label = 'Almandino · Compound Gin' -%}
{%- assign tag_class = 'product-tag' -%}
{%- assign price_class = 'product-form__price--gin' -%}
{%- assign label_class = 'org-label--gin' -%}
{%- assign btn_class = 'btn--primary' -%}
{%- if is_bitter -%}
  {%- assign hero_class = 'product-hero--bitter' -%}
  {%- assign tag_label = 'Spessartina · Bitter artigianale' -%}
  {%- assign tag_class = 'product-tag eyebrow--amber' -%}
  {%- assign price_class = 'product-form__price--bitter' -%}
  {%- assign label_class = 'org-label--bitter' -%}
  {%- assign btn_class = 'btn--amber' -%}
{%- endif -%}

<!-- Breadcrumbs -->
{%- render 'breadcrumbs' -%}

<!-- Recently Viewed tracking data (read by JS) -->
<div id="product-tracking-data"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-url="{{ product.url }}"
  data-product-image="{{ product.featured_image | image_url: width: 400 }}"
  data-product-price="{{ product.price | money }}"
  hidden></div>

<!-- Product Hero -->
<div class="product-hero {{ hero_class }}">
  <div>
    <p class="eyebrow {% if is_bitter %}eyebrow--amber{% endif %}">{{ tag_label }}</p>
    <h1 class="product-hero__title">{{ product.title }}</h1>
    <p class="product-hero__sub">
      {%- for variant in product.variants limit: 1 -%}
        {{ variant.title }} ·
      {%- endfor -%}
      {{ product.metafields.custom.volume | default: '700 ml' }}
    </p>
  </div>
</div>

<!-- Product Detail -->
<div class="product-detail">

  <!-- Visual -->
  <div class="product-detail__visual">
    <div class="product-detail__image">
      {%- if product.featured_image != blank -%}
        <a href="{{ product.featured_image | image_url: width: 1600 }}"
           data-lightbox-src="{{ product.featured_image | image_url: width: 1600 }}"
           aria-label="Ingrandisci immagine">
          {{ product.featured_image | image_url: width: 800 | image_tag:
            loading: 'eager',
            alt: product.featured_image.alt | escape
          }}
        </a>
      {%- else -%}
        <div style="width:100%;aspect-ratio:2/3;background:var(--color-card);display:flex;align-items:center;justify-content:center;">
          <span style="color:var(--color-border);font-size:.7rem;letter-spacing:.2em;">IMMAGINE PRODOTTO</span>
        </div>
      {%- endif -%}

      <!-- Thumbnail gallery -->
      {%- if product.images.size > 1 -%}
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem;margin-top:.75rem;">
          {%- for image in product.images limit: 4 -%}
            <button
              onclick="document.querySelector('.product-detail__image img').src='{{ image | image_url: width: 800 }}';document.querySelector('.product-detail__image a').href='{{ image | image_url: width: 1600 }}';document.querySelector('.product-detail__image a').dataset.lightboxSrc='{{ image | image_url: width: 1600 }}';"
              style="border:1px solid var(--color-border);background:var(--color-card);overflow:hidden;aspect-ratio:1;cursor:pointer;"
              aria-label="Mostra immagine {{ forloop.index }}"
            >
              {{ image | image_url: width: 150 | image_tag: loading: 'lazy', alt: image.alt }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- Info -->
  <div class="product-detail__info">
    <p class="eyebrow {% if is_bitter %}eyebrow--amber{% endif %}" style="margin-bottom:.4rem;">{{ tag_label }}</p>
    <h2>{{ product.title }}</h2>

    {%- if product.description != blank -%}
      <div class="product-detail__tagline">
        {{ product.description }}
      </div>
    {%- endif -%}

    <!-- Specs -->
    <div class="product-specs">
      {%- if product.metafields.custom.tipologia != blank -%}
        <div class="spec">
          <span class="spec__label">Tipologia</span>
          <span class="spec__value">{{ product.metafields.custom.tipologia }}</span>
        </div>
      {%- endif -%}
      {%- if product.metafields.custom.gradazione != blank -%}
        <div class="spec">
          <span class="spec__label">Gradazione</span>
          <span class="spec__value">{{ product.metafields.custom.gradazione }}</span>
        </div>
      {%- endif -%}
      {%- if product.metafields.custom.volume != blank -%}
        <div class="spec">
          <span class="spec__label">Formato</span>
          <span class="spec__value">{{ product.metafields.custom.volume }}</span>
        </div>
      {%- endif -%}
      {%- if product.metafields.custom.residuo_zuccherino != blank -%}
        <div class="spec">
          <span class="spec__label">Residuo zucch.</span>
          <span class="spec__value">{{ product.metafields.custom.residuo_zuccherino }}</span>
        </div>
      {%- endif -%}
    </div>

    <!-- Botanicals -->
    {%- if product.metafields.custom.botaniche != blank -%}
      <div class="info-block">
        <h4 class="info-block__title">Botaniche principali</h4>
        <div class="botanicals">
          {%- if product.metafields.custom.botaniche.type == 'list.single_line_text_field' -%}
            {%- comment -%}Metafield tipo Lista — ogni voce è un elemento separato{%- endcomment -%}
            {%- for b in product.metafields.custom.botaniche.value -%}
              <span class="botanical">{{ b }}</span>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%}Metafield tipo Testo — valori separati da virgola{%- endcomment -%}
            {%- assign botaniche_list = product.metafields.custom.botaniche | split: ',' -%}
            {%- for b in botaniche_list -%}
              <span class="botanical">{{ b | strip }}</span>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <!-- Organoleptic -->
    {%- if product.metafields.custom.olfatto != blank or product.metafields.custom.gusto != blank or product.metafields.custom.finale != blank -%}
      <div class="info-block">
        <h4 class="info-block__title">Profilo organolettico</h4>
        <div class="organoleptic">
          {%- if product.metafields.custom.olfatto != blank -%}
            <div class="org-row">
              <span class="org-label {{ label_class }}">Olfatto</span>
              <span class="org-text">{{ product.metafields.custom.olfatto }}</span>
            </div>
          {%- endif -%}
          {%- if product.metafields.custom.gusto != blank -%}
            <div class="org-row">
              <span class="org-label {{ label_class }}">Gusto</span>
              <span class="org-text">{{ product.metafields.custom.gusto }}</span>
            </div>
          {%- endif -%}
          {%- if product.metafields.custom.finale != blank -%}
            <div class="org-row">
              <span class="org-label {{ label_class }}">Finale</span>
              <span class="org-text">{{ product.metafields.custom.finale }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <!-- Add to cart form -->
    {%- form 'product', product, data-product-form: '', id: 'product-form-main' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      <div class="product-form" id="product-form-anchor">
        <div class="product-form__price {{ price_class }}" id="product-main-price">
          {{ product.selected_or_first_available_variant.price | money }}
        </div>

        <div class="product-form__row">
          <div class="qty-selector" aria-label="Quantità">
            <button type="button" class="qty-selector__btn" onclick="changeQty('product-qty', -1)" aria-label="Riduci quantità">−</button>
            <span class="qty-selector__val" data-qty-id="product-qty" data-qty-value>1</span>
            <button type="button" class="qty-selector__btn" onclick="changeQty('product-qty', 1)" aria-label="Aumenta quantità">+</button>
          </div>

          {%- if product.available -%}
            <button type="submit" class="btn {{ btn_class }} btn-add-cart" data-add-cart>
              Aggiungi al carrello
            </button>
          {%- else -%}
            <button type="button" class="btn btn--outline btn-add-cart" disabled>
              Non disponibile
            </button>
          {%- endif -%}

          <!-- Wishlist button -->
          <button type="button"
            class="btn-wishlist{% if is_bitter %} btn-wishlist--amber{% endif %}"
            data-wishlist-id="{{ product.id }}"
            data-wishlist-title="{{ product.title | escape }}"
            aria-label="Aggiungi alla wishlist"
            title="Aggiungi alla wishlist">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </button>
        </div>
      </div>
    {%- endform -%}

    <!-- Social share -->
    {%- render 'social-share', url: product.url, title: product.title -%}

  </div>
</div>

<!-- Sticky ATC bar (activated by JS when form scrolls out of view) -->
<div id="sticky-atc" class="sticky-atc" aria-hidden="true">
  <div class="sticky-atc__inner">
    <span class="sticky-atc__name">{{ product.title }}</span>
    <span class="sticky-atc__price {{ price_class }}">{{ product.selected_or_first_available_variant.price | money }}</span>
    <button class="btn {{ btn_class }} sticky-atc__btn"
      onclick="document.querySelector('[data-add-cart]')?.click()"
      aria-label="Aggiungi al carrello">
      Aggiungi al carrello
    </button>
  </div>
</div>

<!-- Reviews section -->
<div class="reviews-section" id="reviews">
  <div class="reviews-section__header">
    <h3 class="reviews-section__title">Recensioni</h3>
    <button class="reviews-section__toggle btn btn--outline"
      onclick="document.getElementById('review-form-wrap').classList.toggle('open')"
      aria-expanded="false">
      Scrivi una recensione
    </button>
  </div>

  <!-- Write review form (collapsible) -->
  <div id="review-form-wrap" class="review-form-wrap">
    <form id="review-form" class="review-form" data-product-id="{{ product.id }}">
      <div class="review-form__field">
        <label class="review-form__label" for="review-name">Nome</label>
        <input type="text" id="review-name" name="name" class="review-form__input" placeholder="Il tuo nome" required>
      </div>
      <div class="review-form__field">
        <label class="review-form__label">Valutazione</label>
        <div class="review-form__stars" role="group" aria-label="Valutazione in stelle">
          {%- for i in (1..5) -%}
            <button type="button" class="review-form__star" data-star="{{ i }}" aria-label="{{ i }} stell{% if i == 1 %}a{% else %}e{% endif %}">★</button>
          {%- endfor -%}
        </div>
        <input type="hidden" id="review-rating-input" name="rating" value="0">
      </div>
      <div class="review-form__field">
        <label class="review-form__label" for="review-body">La tua recensione</label>
        <textarea id="review-body" name="body" class="review-form__textarea" rows="4" placeholder="Raccontaci la tua esperienza con questo prodotto…" required></textarea>
      </div>
      <button type="submit" class="btn {{ btn_class }}">Invia recensione</button>
    </form>
  </div>

  <!-- Reviews list (populated by Shopify Reviews app or custom metafields) -->
  <div class="reviews-list" id="reviews-list">
    <p class="reviews-empty" style="color:var(--color-gray);font-size:.85rem;padding:2rem 0;">
      Ancora nessuna recensione. Sii il primo a condividere la tua esperienza!
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Main Product",
  "settings": []
}
{% endschema %}
