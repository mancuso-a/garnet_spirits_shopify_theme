{%- comment -%}
  Standalone wishlist button snippet.
  Usage: {% render 'wishlist-btn', product: product %}
  Can also pass is_bitter: true/false for amber styling.
{%- endcomment -%}

<button
  class="btn-wishlist{% if is_bitter %} btn-wishlist--amber{% endif %}"
  data-wishlist-id="{{ product.id }}"
  data-wishlist-title="{{ product.title | escape }}"
  aria-label="Aggiungi alla wishlist"
  title="Aggiungi alla wishlist">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </svg>
</button>
